{
  "name": "argus",
  "version": "0.1.0",
  "description": "Multimodal fusion analysis — TradingView + LLM",
  "main": "out/main/index.js",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "better-sqlite3"
    ]
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "preview": "electron-vite preview",
    "test:dashscope": "node tests/dashscope-generation-demo.test.js",
    "test:okx": "node --test tests/trading-agent-okx-integration.test.js",
    "test:okx:agent": "node --test tests/trading-agent-okx-integration.test.js",
    "test:agent-tools": "node --test tests/trading-agent-executor.test.js tests/trading-agent-tools-schema.test.js tests/okx-attach-algo.test.js tests/okx-pending-algo-serialize.test.js tests/okx-recent-candles.test.js tests/ema-series.test.js tests/crypto-scheduler.test.js"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^34.0.0",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
