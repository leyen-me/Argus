{
  "name": "argus",
  "version": "0.1.0",
  "type": "module",
  "description": "Multimodal fusion analysis — TradingView + LLM",
  "main": "src/server/index.ts",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "scripts": {
    "postinstall": "tsx scripts/rebuild-sqlite.ts",
    "rebuild:native": "tsx scripts/rebuild-sqlite.ts",
    "start": "tsx src/server/index.ts",
    "server": "tsx src/server/index.ts",
    "server:dev": "tsx src/server/index.ts",
    "client:dev": "vite",
    "build": "vite build",
    "dev": "concurrently -n srv,vite -c blue,green \"npm run server:dev\" \"npm run client:dev\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^6.4.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "countup.js": "^2.10.0",
    "express": "^4.21.2",
    "lucide-react": "^1.8.0",
    "nodemailer": "^6.9.16",
    "openai": "^6.34.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.3.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0"
  }
}
