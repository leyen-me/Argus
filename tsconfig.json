{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "allowJs": false,
    "paths": {
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "include": ["vite.config.ts", "src/renderer/src/**/*.ts", "src/renderer/src/**/*.tsx"]
}
